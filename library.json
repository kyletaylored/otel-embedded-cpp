{
  "name": "otel-embedded-cpp",
  "version": "1.1.0",
  "description": "OpenTelemetry logging, tracing, and metrics for embedded C++ devices (ESP32, RP2040 Pico W, ESP8266).",
  "keywords": [
    "OpenTelemetry",
    "telemetry",
    "logging",
    "tracing",
    "metrics",
    "embedded",
    "iot",
    "esp32",
    "pico",
    "esp8266"
  ],
  "authors": [
    {
      "name": "Matthew Macdonald-Wallace",
      "maintainer": true
    }
  ],
  "license": "MIT",
  "frameworks": ["arduino"],
  "platforms": [
    "espressif32",
    "espressif8266",
    "raspberrypi"
  ],
  "dependencies": [
    {
      "name": "ArduinoJson",
      "version": "^7.0.0"
    },
    {
      "name": "nanopb/Nanopb",
      "version": "^0.4.91"
    }
  ],
  "build": {
    "srcFilter": ["+<*.cpp>", "-<main.cpp>"]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/proffalken/otel-embedded-cpp.git"
  },
  "examples": [
    {
      "name": "Basic",
      "base": "examples/basic",
      "files": ["main.cpp", "README.md"]
    },
    {
      "name": "Direct OTLP",
      "base": "examples/direct_otlp",
      "files": ["main.cpp", "README.md"]
    },
    {
      "name": "Protobuf OTLP",
      "base": "examples/proto_otlp",
      "files": ["main.cpp"]
    }
  ]
}
